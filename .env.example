MongoDbSettings__ConnectionString=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MongoDbSettings__DatabaseName=BeatWatchDb_Dev
JwtSettings__Issuer=https://api.beatwatch.example
JwtSettings__Audience=beatwatch-web
JwtSettings__SigningKey=<at-least-32-random-characters>
JwtSettings__ExpirationMinutes=15
RecaptchaSettings__SecretKey=<recaptcha-server-secret>
RecaptchaSettings__MinimumScore=0.5
RecaptchaSettings__ExpectedAction=login
